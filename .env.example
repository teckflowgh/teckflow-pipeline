# ============================================================
# AUTOMATED VIDEO PIPELINE — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Anthropic (Claude Haiku for script generation) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- YouTube Data API v3 (free, 10,000 units/day) ---
# Get key at: https://console.cloud.google.com → YouTube Data API v3
YOUTUBE_API_KEY=AIza...
# YouTube category ID to search (28 = Science & Tech, 22 = People & Blogs)
YOUTUBE_CATEGORY_ID=28

# --- VidIQ (only needed if TOPIC_SOURCE=vidiq) ---
VIDIQ_EMAIL=you@example.com
VIDIQ_PASSWORD=yourpassword

# --- Pexels API (gratis B-roll stockvideo's) ---
# Gratis sleutel aanvragen: https://www.pexels.com/api/
PEXELS_API_KEY=

# --- Pictory API (optioneel, niet meer vereist) ---
# Pictory biedt momenteel geen API toegang aan op consumentenplannen.
# De pipeline gebruikt Pexels + Whisper + FFmpeg als vervanging.
PICTORY_CLIENT_ID=
PICTORY_CLIENT_SECRET=
PICTORY_USER_ID=

# --- Email Alerting (optional — uses Gmail App Password or SMTP relay) ---
ALERT_EMAIL_FROM=alerts@yourdomain.com
ALERT_EMAIL_TO=you@yourdomain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@yourdomain.com
SMTP_PASSWORD=your_gmail_app_password

# --- Webhook Alerting (optional — Slack, Discord, Make.com, n8n) ---
# Slack example: https://hooks.slack.com/services/T.../B.../xxx
ALERT_WEBHOOK_URL=

# --- Pipeline Behaviour ---
SCHEDULE_TIME=06:00
TIMEZONE=Europe/Brussels
# Options: youtube | vidiq
TOPIC_SOURCE=youtube
# Video script language code (en, nl, fr, de, es)
SCRIPT_LANGUAGE=nl

# --- GPU ---
USE_GPU=true
LIVEPORTRAIT_PATH=third_party/LivePortrait
SADTALKER_PATH=third_party/SadTalker
WAV2LIP_PATH=third_party/Wav2Lip
# Path to your 5-10 sec reference video clip (overrides default assets/reference_clip.mp4)
REFERENCE_CLIP=assets/reference_clip.mp4

# --- RunPod (automatisch pod starten/stoppen) ---
RUNPOD_API_KEY=rpa_...
RUNPOD_POD_ID=amstht1ip2g8bi
RUNPOD_GPU_TYPE=NVIDIA GeForce RTX 3090
VIDEO_MODE_DEFAULT=short

# --- FastAPI Server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Next.js Dashboard (set this in dashboard/.env.local too) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
